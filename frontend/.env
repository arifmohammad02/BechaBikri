// ==========================================
// Environment Detection
// ==========================================
const isDevelopment = import.meta.env.DEV;

// ==========================================
// ⭐ Backend URL - .env এর মতো হতে হবে
// ==========================================
// VITE_API_URL=https://bechabikri-1.onrender.com (from .env)
const RENDER_BACKEND_URL = "https://bechabikri-1.onrender.com"; // ✅ Space নেই, সঠিক URL

// ==========================================
// Base URLs
// ==========================================
export const BASE_URL = isDevelopment ? "" : RENDER_BACKEND_URL;
export const API_URL = isDevelopment ? "" : RENDER_BACKEND_URL;

// ==========================================
// API Endpoints
// ==========================================
export const USERS_URL = "/api/users";
export const CATEGORY_URL = "/api/category";
export const PRODUCT_URL = "/api/products";
export const UPLOAD_URL = "/api/upload";
export const ORDERS_URL = "/api/orders";
export const NOTIFICATIONS_URL = "/api/notifications";
export const BANNER_URL = "/api/banners";
export const PAYMENTS_URL = "/api/payments";

// Order payment URL builder
export const ORDER_PAY_URL = (orderId) => `/api/orders/${orderId}/pay`;

// ==========================================
// Socket.io URL
// ==========================================
export const SOCKET_URL = isDevelopment 
  ? "http://localhost:8000" 
  : RENDER_BACKEND_URL;

// ==========================================
// Uploads URL for images
// ==========================================
export const UPLOADS_URL = isDevelopment 
  ? "http://localhost:8000/uploads" 
  : `${RENDER_BACKEND_URL}/uploads`;

// ==========================================
// Frontend URL (for redirects/emails)
// ==========================================
export const FRONTEND_URL = isDevelopment
  ? "http://localhost:5173"
  : "https://becha-bikri-9ygt.vercel.app";

// ==========================================
// Debug Helper (Development only)
// ==========================================
if (isDevelopment) {
  console.log("🔧 Development Mode");
  console.log("BASE_URL:", BASE_URL);
  console.log("API_URL:", API_URL);
  console.log("SOCKET_URL:", SOCKET_URL);
} else {
  console.log("🚀 Production Mode");
  console.log("API_URL:", API_URL);
  console.log("SOCKET_URL:", SOCKET_URL);
}